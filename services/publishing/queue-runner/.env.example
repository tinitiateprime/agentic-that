PUBLISH_QUEUE_SERVICE_PORT=8792
PUBLISH_QUEUE_WEB_ORIGIN=http://127.0.0.1:3000,http://localhost:3000,https://agenticthat.netlify.app
PUBLISH_QUEUE_AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
PUBLISH_QUEUE_SCHEDULER_ENABLED=true
PUBLISH_QUEUE_SCHEDULER_CRON=* * * * *
